# Copy to .env, fill GOOGLE_CLOUD_PROJECT, then `./setup.sh` and `adk web agents`.
# Reproducible on any laptop.
#
# IMPORTANT — verified against project YOUR_PROJECT_ID on 2026-07-17:
#   * gemini-3.5-flash is served ONLY on the `global` endpoint (404 in us-central1).
#   * The Live API (voice) is served ONLY in a region (us-central1); NOT on global.
#   So the two demos use DIFFERENT locations. See the two blocks below.

GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID

# ============================================================
# DEMO 1 (basic) + DEMO 2 typed  ->  newest model, global
# ============================================================
GOOGLE_CLOUD_LOCATION=global
TEXT_MODEL=gemini-3.5-flash
# Leave VOICE_MODEL unset here so demo2 runs typed on the text model.

# ============================================================
# DEMO 2 VOICE  ->  Live model, us-central1  (switch to these for the mic demo)
# ============================================================
# GOOGLE_CLOUD_LOCATION=us-central1
# TEXT_MODEL=gemini-2.5-flash                       # sub-agents (3.5-flash is global-only)
# VOICE_MODEL=gemini-live-2.5-flash-native-audio    # root, drives the mic

# --- Alternative: AI Studio API key instead of Vertex ---
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your-aistudio-key
